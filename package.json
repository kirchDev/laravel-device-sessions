{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@kirchdev/laravel-device-sessions",
  "version": "0.1.0",
  "private": true,
  "description": "Dev tooling for kirchdev/laravel-device-sessions (Composer package).",
  "homepage": "https://github.com/kirchDev/laravel-device-sessions",
  "bugs": {
    "url": "https://github.com/kirchDev/laravel-device-sessions/issues"
  },
  "license": "MIT",
  "author": "Titus Kirch <titus.kirch@kirch.dev> (https://kirch.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirchDev/laravel-device-sessions.git"
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "check": "pnpm lint && pnpm format",
    "check:fix": "pnpm lint:fix && pnpm format:fix",
    "taze": "taze",
    "taze:w": "taze -w",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "taze": "^19.11.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.8"
}
