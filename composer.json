{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "kirchdev/laravel-device-sessions",
  "description": "Device-bound login sessions for Laravel: per-device remember-me tokens, a \"where am I signed in\" device list, and revoke/rename — privacy-respecting and Fortify-agnostic.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "authentication",
    "devices",
    "sessions",
    "remember-me",
    "security",
    "device-management"
  ],
  "authors": [
    {
      "name": "Titus Kirch",
      "email": "titus.kirch@kirch.dev",
      "homepage": "https://kirch.dev",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/kirchDev/laravel-device-sessions",
  "support": {
    "issues": "https://github.com/kirchDev/laravel-device-sessions/issues",
    "source": "https://github.com/kirchDev/laravel-device-sessions"
  },
  "require": {
    "php": "^8.4",
    "illuminate/auth": "^13.0",
    "illuminate/cache": "^13.0",
    "illuminate/console": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/cookie": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/support": "^13.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.9",
    "laravel/fortify": "^1.0",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.7",
    "pestphp/pest-plugin-laravel": "^4.1"
  },
  "suggest": {
    "laravel/fortify": "Auto-wires the two-factor challenge device-cookie bridge when present."
  },
  "autoload": {
    "psr-4": {
      "KirchDev\\DeviceSessions\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "KirchDev\\DeviceSessions\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:fast": "vendor/bin/pest --compact --parallel",
    "test:coverage": [
      "Composer\\Config::disableProcessTimeout",
      "@php -d pcov.directory=src vendor/bin/pest --compact --coverage --min=0"
    ],
    "pint": "vendor/bin/pint --test",
    "pint:fix": "vendor/bin/pint",
    "larastan": "vendor/bin/phpstan analyse --memory-limit=512M"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.x-dev"
    },
    "laravel": {
      "providers": [
        "KirchDev\\DeviceSessions\\DeviceSessionsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
